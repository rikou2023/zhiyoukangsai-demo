<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>智优康赛官网 · 配色方案预览 · 12 套</title>
  <link rel="icon" type="image/svg+xml" href="favicon.svg" />
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      background: var(--bg);
      color: var(--text);
      font-family: "HarmonyOS Sans SC", "MiSans", "PingFang SC", "Microsoft YaHei", system-ui, sans-serif;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      transition: background 250ms ease, color 250ms ease;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }
    img { display: block; max-width: 100%; }
    button { font: inherit; cursor: pointer; border: none; }
    a { color: inherit; text-decoration: none; }

    /* ===== Hero 主体 ===== */
    .hero {
      flex: 1;
      position: relative;
      min-height: calc(100vh - 88px);
      display: flex;
      flex-direction: column;
      transition: background 250ms ease;
    }
    .hero::before {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      background-image:
        linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
      background-size: 80px 80px;
      mask-image: radial-gradient(ellipse 80% 70% at 50% 30%, #000 25%, transparent 75%);
    }
    body[data-light="true"] .hero::before {
      background-image:
        linear-gradient(rgba(0,0,0,0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0,0,0,0.04) 1px, transparent 1px);
    }
    .hero::after {
      content: "";
      position: absolute;
      top: -100px;
      left: 50%;
      transform: translateX(-50%);
      width: 900px;
      height: 700px;
      background: radial-gradient(ellipse, color-mix(in srgb, var(--accent) 12%, transparent) 0%, transparent 70%);
      pointer-events: none;
    }

    /* 顶栏 */
    .mini-header {
      position: relative;
      z-index: 2;
      padding: 20px 40px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
    }
    .mini-header .brand img { height: 44px; }
    .mini-nav {
      display: flex;
      gap: 4px;
      margin: 0 auto;
    }
    .mini-nav a {
      padding: 8px 14px;
      font-size: 14px;
      color: var(--muted);
      font-weight: 500;
      transition: color 150ms;
    }
    .mini-nav a:hover { color: var(--text); }
    .mini-actions {
      display: flex;
      gap: 10px;
      align-items: center;
    }
    .btn-ghost {
      padding: 8px 16px;
      font-size: 14px;
      color: var(--muted);
      background: transparent;
      border-radius: 8px;
    }
    .btn-primary {
      background: var(--cta);
      color: var(--cta-text);
      padding: 0 22px;
      height: 44px;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 600;
      transition: background 150ms;
    }
    .btn-primary:hover { background: var(--cta-hover); }
    .btn-primary.lg { height: 52px; padding: 0 28px; font-size: 16px; }

    /* Hero 居中 */
    .hero-center {
      position: relative;
      z-index: 2;
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 48px 40px 64px;
    }
    .mini-title {
      margin: 0 0 28px;
      font-weight: 700;
      letter-spacing: -0.02em;
      line-height: 1.1;
    }
    .mini-title .line { display: block; }
    .mini-title .line + .line { margin-top: clamp(12px, 1.6vw, 24px); }
    .line-1 {
      font-size: clamp(36px, 5.4vw, 72px);
      color: var(--text);
    }
    .line-2 {
      font-size: clamp(24px, 3.2vw, 44px);
      color: var(--muted);
    }
    .line-3 {
      font-size: clamp(44px, 7vw, 104px);
      color: var(--text);
      letter-spacing: -0.025em;
    }
    .platform-chip {
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }
    .platform-chip img {
      width: 0.9em;
      height: 0.9em;
      border-radius: 0.18em;
    }
    .platform-chip strong {
      color: var(--text);
      font-weight: 700;
    }
    .gradient-text {
      background: linear-gradient(135deg, var(--grad-from) 0%, var(--grad-mid) 35%, var(--grad-to) 100%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      -webkit-text-fill-color: transparent;
    }
    .mini-subtitle {
      max-width: 640px;
      font-size: clamp(16px, 1.4vw, 20px);
      color: var(--muted);
      margin: 0 0 36px;
      line-height: 1.5;
    }
    .mini-ctas {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      justify-content: center;
    }
    .btn-secondary {
      background: transparent;
      color: var(--text);
      border: 1px solid var(--border-strong);
      padding: 0 28px;
      height: 52px;
      border-radius: 8px;
      font-size: 16px;
      font-weight: 600;
      transition: border-color 150ms, color 150ms;
    }
    .btn-secondary:hover {
      border-color: var(--accent);
      color: var(--accent);
    }

    /* 跑马灯（自动滚动） */
    .mini-marquee {
      position: relative;
      z-index: 2;
      padding: 32px 0 40px;
      overflow: hidden;
      mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
    }
    .marquee-track {
      display: flex;
      gap: 80px;
      animation: marquee 36s linear infinite;
      width: max-content;
      align-items: center;
    }
    @keyframes marquee {
      from { transform: translateX(0); }
      to { transform: translateX(-50%); }
    }
    .mini-platform-logo {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      color: var(--muted);
      font-size: 16px;
      font-weight: 500;
      opacity: 0.65;
      transition: opacity 150ms;
      flex-shrink: 0;
    }
    .mini-platform-logo:hover { opacity: 1; }
    .mini-platform-logo img {
      width: 44px;
      height: 44px;
      object-fit: contain;
    }

    /* ====================================
       底部主题切换栏（QA 工具）
       ==================================== */
    .theme-bar {
      position: sticky;
      bottom: 0;
      z-index: 50;
      background: rgba(8, 8, 10, 0.92);
      backdrop-filter: blur(20px);
      border-top: 1px solid #1f2937;
      padding: 14px 24px;
      display: flex;
      align-items: center;
      gap: 16px;
    }
    .theme-bar-label {
      font-family: "JetBrains Mono", "SF Mono", monospace;
      font-size: 11px;
      color: #64748b;
      letter-spacing: 0.15em;
      flex-shrink: 0;
    }
    .theme-bar-current {
      flex-shrink: 0;
      color: #fafafa;
      font-size: 13px;
      font-weight: 600;
      padding-left: 12px;
      border-left: 1px solid #1f2937;
    }
    .theme-bar-current span {
      color: #64748b;
      font-weight: 400;
      margin-left: 6px;
    }
    .theme-bar-buttons {
      flex: 1;
      display: flex;
      gap: 6px;
      overflow-x: auto;
      scrollbar-width: thin;
      padding-bottom: 2px;
    }
    .theme-bar-buttons::-webkit-scrollbar { height: 4px; }
    .theme-bar-buttons::-webkit-scrollbar-thumb { background: #374151; border-radius: 2px; }

    .theme-btn {
      flex-shrink: 0;
      display: inline-flex;
      flex-direction: column;
      align-items: center;
      gap: 6px;
      padding: 8px 10px;
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 8px;
      color: #fafafa;
      transition: background 150ms, border-color 150ms, transform 150ms;
      min-width: 64px;
    }
    .theme-btn:hover {
      background: rgba(255, 255, 255, 0.08);
      transform: translateY(-1px);
    }
    .theme-btn.active {
      border-color: #06b6d4;
      background: rgba(6, 182, 212, 0.12);
    }
    .theme-btn-swatches {
      display: flex;
      gap: 2px;
    }
    .theme-btn-swatches span {
      width: 10px;
      height: 18px;
      border-radius: 2px;
    }
    .theme-btn-key {
      font-family: "JetBrains Mono", monospace;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.05em;
    }

    @media (max-width: 768px) {
      .mini-header { padding: 16px 20px; }
      .mini-nav { display: none; }
      .hero-center { padding: 32px 20px 48px; }
      .theme-bar { padding: 10px 12px; gap: 10px; }
      .theme-bar-label { display: none; }
      .theme-bar-current { padding-left: 0; border-left: none; font-size: 11px; }
    }
  </style>
</head>
<body data-theme="A">

  <!-- ===== Hero 预览（吃主题变量） ===== -->
  <section class="hero">
    <header class="mini-header">
      <a class="brand"><img src="images/智优康赛logo.svg" alt="智优康赛"></a>
      <nav class="mini-nav">
        <a>GEO服务</a><a>解决方案</a><a>客户评价</a><a>生态与合作</a><a>系统演示</a><a>关于我们</a>
      </nav>
      <div class="mini-actions">
        <button class="btn-ghost">联系我们</button>
        <button class="btn-primary">预约诊断</button>
      </div>
    </header>

    <div class="hero-center">
      <h1 class="mini-title">
        <span class="line line-1">让您的品牌占领</span>
        <span class="line line-2">
          <span class="platform-chip" id="platform-chip">
            <img src="data:image/png;base64," alt="">
            <strong>Kimi</strong>
          </span>
        </span>
        <span class="line line-3">的<span class="gradient-text">第一推荐位</span></span>
      </h1>

      <p class="mini-subtitle">中国 GEO 第一服务商，让每一个优秀的企业都能被世界看见。</p>

      <div class="mini-ctas">
        <button class="btn-primary lg">预约诊断</button>
        <button class="btn-secondary">联系我们 →</button>
      </div>
    </div>

    <div class="mini-marquee">
      <div class="marquee-track" id="marquee-track"></div>
    </div>
  </section>

  <!-- ===== 底部主题切换栏 ===== -->
  <div class="theme-bar">
    <span class="theme-bar-label">THEME</span>
    <span class="theme-bar-current" id="current-name">A · Logo 原生配色<span id="current-source"></span></span>
    <div class="theme-bar-buttons" id="theme-buttons"></div>
  </div>

  <script>
    /* ============================================
       12 套配色方案
       ============================================ */
    const THEMES = [
      { key: 'A', name: 'Logo 原生配色', source: '取自智优康赛 Logo · 最忠实',
        bg: '#050A14', surface: '#0B1525', text: '#F5F8FC', muted: '#94A8C2', border: '#14223A', borderStrong: '#1F3454',
        brand: '#036EB8', accent: '#2EA7E0', cta: '#C30D23', ctaHover: '#DC2C42', ctaText: '#FFFFFF',
        gradFrom: '#2EA7E0', gradMid: '#036EB8', gradTo: '#172A88' },

      { key: 'B', name: 'Linear 工程师感', source: '黑 + 电光绿 + 白按钮',
        bg: '#08090A', surface: '#131316', text: '#F4F4F5', muted: '#A1A1AA', border: '#27272A', borderStrong: '#3F3F46',
        brand: '#FAFAFA', accent: '#4ADE80', cta: '#FAFAFA', ctaHover: '#E5E5E5', ctaText: '#08090A',
        gradFrom: '#86EFAC', gradMid: '#4ADE80', gradTo: '#22C55E' },

      { key: 'C', name: 'Anthropic 暖橘', source: '黑 + 暖橘 + 深紫 · 学院派',
        bg: '#0D0D0D', surface: '#1A1A1A', text: '#F5F3F0', muted: '#A1A1AA', border: '#262626', borderStrong: '#3F3F46',
        brand: '#D97757', accent: '#8B5CF6', cta: '#D97757', ctaHover: '#E58869', ctaText: '#0D0D0D',
        gradFrom: '#FBBF24', gradMid: '#D97757', gradTo: '#C2410C' },

      { key: 'D', name: 'Stripe 深蓝紫', source: '深海军 + 品牌紫 + 琥珀 · KA',
        bg: '#0A2540', surface: '#122B4F', text: '#F5F7FF', muted: '#A7B5D1', border: '#1A3760', borderStrong: '#2A4A78',
        brand: '#635BFF', accent: '#00D4FF', cta: '#FFAC4B', ctaHover: '#FFC067', ctaText: '#0A2540',
        gradFrom: '#00D4FF', gradMid: '#635BFF', gradTo: '#A78BFA' },

      { key: 'E', name: '中国 AI 风', source: '雾灰墨青 + 青绿 + 朱砂橙',
        bg: '#0B1015', surface: '#161E27', text: '#F1EFE9', muted: '#9CA3AF', border: '#1F2A36', borderStrong: '#374151',
        brand: '#E8E6E1', accent: '#00C7B7', cta: '#FF7A45', ctaHover: '#FF9468', ctaText: '#0B1015',
        gradFrom: '#00C7B7', gradMid: '#2DD4BF', gradTo: '#FF7A45' },

      { key: 'F', name: 'OpenAI 黑白极简', source: '纯黑白 + OpenAI 绿',
        bg: '#000000', surface: '#0A0A0A', text: '#ECECEC', muted: '#8E8EA0', border: '#1F1F1F', borderStrong: '#2F2F2F',
        brand: '#10A37F', accent: '#10A37F', cta: '#FFFFFF', ctaHover: '#F0F0F0', ctaText: '#000000',
        gradFrom: '#10A37F', gradMid: '#19C37D', gradTo: '#5DDDA1' },

      { key: 'G', name: 'DeepSeek 深紫蓝', source: '靛紫 + 亮青 · 像 DeepSeek',
        bg: '#0F0E1A', surface: '#1A1830', text: '#F0F0FF', muted: '#9CA3AF', border: '#1E1B3D', borderStrong: '#2D2A50',
        brand: '#5C5BFF', accent: '#00D9FF', cta: '#5C5BFF', ctaHover: '#7674FF', ctaText: '#FFFFFF',
        gradFrom: '#00D9FF', gradMid: '#5C5BFF', gradTo: '#8B7DFF' },

      { key: 'H', name: 'Perplexity 青绿', source: '深青 + 翡翠 · 像 Perplexity',
        bg: '#0A1010', surface: '#161F1F', text: '#F5FAFA', muted: '#A0AEAE', border: '#1F2A2A', borderStrong: '#2D3D3D',
        brand: '#20808D', accent: '#00C9A7', cta: '#20808D', ctaHover: '#2A9CAC', ctaText: '#FFFFFF',
        gradFrom: '#00C9A7', gradMid: '#20808D', gradTo: '#0F4751' },

      { key: 'I', name: 'NVIDIA 黑绿', source: '纯黑 + NVIDIA 绿 · 算力公司',
        bg: '#000000', surface: '#0F0F0F', text: '#FFFFFF', muted: '#A0A0A0', border: '#1F1F1F', borderStrong: '#333333',
        brand: '#76B900', accent: '#76B900', cta: '#76B900', ctaHover: '#8FCC1F', ctaText: '#000000',
        gradFrom: '#A4E22D', gradMid: '#76B900', gradTo: '#4D7800' },

      { key: 'J', name: 'Apple Pro 银黑', source: '深空灰 + 银白 + 靛蓝',
        bg: '#0A0A0F', surface: '#16161D', text: '#F5F5F7', muted: '#8E8E93', border: '#1C1C24', borderStrong: '#2C2C34',
        brand: '#E8E8ED', accent: '#5E5CE6', cta: '#E8E8ED', ctaHover: '#FFFFFF', ctaText: '#0A0A0F',
        gradFrom: '#64D2FF', gradMid: '#5E5CE6', gradTo: '#BF5AF2' },

      { key: 'K', name: 'Notion 暖灰浅底', source: '白底 + 暖墨棕 · 唯一浅底',
        bg: '#FFFFFF', surface: '#F7F6F3', text: '#37352F', muted: '#787570', border: '#E9E7E2', borderStrong: '#D4D2CC',
        brand: '#2F1F12', accent: '#E89A4F', cta: '#2F1F12', ctaHover: '#4A3320', ctaText: '#FFFFFF',
        gradFrom: '#E89A4F', gradMid: '#C2410C', gradTo: '#7C2D12',
        light: true },

      { key: 'L', name: 'Cloudflare 橙黑', source: '纯黑 + 高饱和橙 · 强转化',
        bg: '#0C0C0C', surface: '#1A1A1A', text: '#FAFAFA', muted: '#9CA3AF', border: '#262626', borderStrong: '#3F3F46',
        brand: '#F38020', accent: '#FFB13A', cta: '#F38020', ctaHover: '#FF9540', ctaText: '#FFFFFF',
        gradFrom: '#FFB13A', gradMid: '#F38020', gradTo: '#C2410C' }
    ];

    const PLATFORMS = [
      { name: 'Kimi', icon: 'data:image/png;base64,' },
      { name: '豆包', icon: 'data:image/png;base64,' },
      { name: '文心一言', icon: 'data:image/png;base64,' },
      { name: 'DeepSeek', icon: 'data:image/png;base64,' },
      { name: '通义千问', icon: 'data:image/png;base64,' },
      { name: '智谱清言', icon: 'data:image/png;base64,' },
      { name: '元宝', icon: 'data:image/png;base64,' }
    ];

    /* ============================================
       渲染主题切换按钮
       ============================================ */
    const btnsContainer = document.getElementById('theme-buttons');
    btnsContainer.innerHTML = THEMES.map(t => `
      <button class="theme-btn" data-key="${t.key}" title="${t.name}">
        <span class="theme-btn-swatches">
          <span style="background:${t.bg}"></span>
          <span style="background:${t.brand}"></span>
          <span style="background:${t.accent}"></span>
          <span style="background:${t.cta}"></span>
        </span>
        <span class="theme-btn-key">${t.key}</span>
      </button>
    `).join('');

    /* ============================================
       渲染跑马灯（双份做无缝滚动）
       ============================================ */
    const track = document.getElementById('marquee-track');
    const logoHtml = PLATFORMS.map(p =>
      `<span class="mini-platform-logo"><img src="${p.icon}" alt=""> ${p.name}</span>`
    ).join('');
    track.innerHTML = logoHtml + logoHtml;

    /* ============================================
       应用主题
       ============================================ */
    function applyTheme(key) {
      const t = THEMES.find(x => x.key === key);
      if (!t) return;
      const root = document.body;
      root.style.setProperty('--bg', t.bg);
      root.style.setProperty('--surface', t.surface);
      root.style.setProperty('--text', t.text);
      root.style.setProperty('--muted', t.muted);
      root.style.setProperty('--border', t.border);
      root.style.setProperty('--border-strong', t.borderStrong);
      root.style.setProperty('--brand', t.brand);
      root.style.setProperty('--accent', t.accent);
      root.style.setProperty('--cta', t.cta);
      root.style.setProperty('--cta-hover', t.ctaHover);
      root.style.setProperty('--cta-text', t.ctaText);
      root.style.setProperty('--grad-from', t.gradFrom);
      root.style.setProperty('--grad-mid', t.gradMid);
      root.style.setProperty('--grad-to', t.gradTo);
      root.setAttribute('data-theme', key);
      root.setAttribute('data-light', t.light ? 'true' : 'false');

      // 更新按钮激活态
      document.querySelectorAll('.theme-btn').forEach(b => {
        b.classList.toggle('active', b.dataset.key === key);
      });

      // 更新顶部当前名
      document.getElementById('current-name').innerHTML =
        `${key} · ${t.name}<span> — ${t.source}</span>`;

      localStorage.setItem('zykys-theme-preview', key);
    }

    /* ============================================
       平台 chip 轮换（每 2.8s 切一个平台）
       ============================================ */
    const chipEl = document.getElementById('platform-chip');
    let pIdx = 0;
    function rotatePlatform() {
      pIdx = (pIdx + 1) % PLATFORMS.length;
      const p = PLATFORMS[pIdx];
      chipEl.style.opacity = '0';
      setTimeout(() => {
        chipEl.querySelector('img').src = p.icon;
        chipEl.querySelector('strong').textContent = p.name;
        chipEl.style.opacity = '1';
      }, 200);
    }
    chipEl.style.transition = 'opacity 200ms ease';
    setInterval(rotatePlatform, 2800);

    /* ============================================
       事件绑定 + 初始化
       ============================================ */
    btnsContainer.addEventListener('click', (e) => {
      const btn = e.target.closest('.theme-btn');
      if (btn) applyTheme(btn.dataset.key);
    });

    const initialKey = localStorage.getItem('zykys-theme-preview') || 'A';
    applyTheme(initialKey);
  </script>
</body>
</html>
